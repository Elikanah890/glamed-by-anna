{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/index.html" },
    { "src": "/services", "dest": "/index.html" },
    { "src": "/gallery", "dest": "/index.html" },
    { "src": "/bridal", "dest": "/index.html" },
    { "src": "/pricing", "dest": "/index.html" },
    { "src": "/testimonials", "dest": "/index.html" },
    { "src": "/book", "dest": "/index.html" },
    { "src": "/faq", "dest": "/index.html" },
    { "src": "/contact", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
